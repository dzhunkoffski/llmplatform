      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(llm_platform_request_duration_seconds_bucket{provider=~\"$provider\"}[$__rate_interval])) by (le, provider))",
          "legendFormat": "{{provider}} p95",
          "refId": "A"
        }
      ],
      "title": "Request Latency p95 by Provider",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
